# ComfyUI Kubernetes Deployment - Qwen/Z-Image Models
# Lightweight image: models downloaded at runtime via SMB PVC

ARG BASE_IMAGE=nvidia/cuda:12.8.0-runtime-ubuntu24.04
ARG COMFYUI_VERSION=latest

FROM ${BASE_IMAGE}

ARG COMFYUI_VERSION

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_PREFER_BINARY=1
ENV PYTHONUNBUFFERED=1
ENV CMAKE_BUILD_PARALLEL_LEVEL=8

RUN apt-get update && apt-get install -y \
    python3.12 \
    python3.12-venv \
    python3-pip \
    git \
    wget \
    curl \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    ffmpeg \
    && ln -sf /usr/bin/python3.12 /usr/bin/python \
    && apt-get autoremove -y \
    && apt-get clean -y \
    && rm -rf /var/lib/apt/lists/*

RUN wget -qO- https://astral.sh/uv/install.sh | sh \
    && ln -s /root/.local/bin/uv /usr/local/bin/uv \
    && ln -s /root/.local/bin/uvx /usr/local/bin/uvx \
    && uv venv /opt/venv

ENV PATH="/opt/venv/bin:${PATH}"

RUN uv pip install comfy-cli pip setuptools wheel

RUN /usr/bin/yes | comfy --workspace /comfyui install --version "${COMFYUI_VERSION}"

RUN uv pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu128

WORKDIR /comfyui

RUN mkdir -p models/checkpoints models/vae models/unet models/clip \
    models/text_encoders models/diffusion_models models/loras \
    models/controlnet models/embeddings models/upscale_models output

WORKDIR /

RUN uv pip install requests websocket-client

# Copy startup scripts
COPY scripts/download-models-qwen.sh /download-models.sh
COPY scripts/start-qwen.sh /start.sh
RUN chmod +x /download-models.sh /start.sh

EXPOSE 8188

HEALTHCHECK --interval=30s --timeout=10s --start-period=600s --retries=5 \
  CMD curl -f http://localhost:8188/ || exit 1

CMD ["/start.sh"]

LABEL org.opencontainers.image.source="https://github.com/tk-aria/comfyui-k8s-deployment"
LABEL org.opencontainers.image.description="ComfyUI for Kubernetes - Qwen/Z-Image models (runtime download)"
LABEL org.opencontainers.image.licenses="MIT"
